# ─── Maven build output ──────────────────────────────────────────────────────
target/
*.class
*.war
*.ear

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs.txt
logs/

# ─── Frontend dependencies & build ──────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ─── LocalStack volume (Docker-managed, not source code) ─────────────────────
volume/

# ─── Environment / secrets ───────────────────────────────────────────────────
.env
*.env
apikey.txt

# ─── IDE & editor ────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Terraform state (local) ─────────────────────────────────────────────────
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl
