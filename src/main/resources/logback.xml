<configuration>

    <!-- Human-readable console logging (default) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{30} [%X{requestId:-}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- JSON structured logging for production (parseable by ELK/Datadog/CloudWatch).
         To activate: replace CONSOLE with JSON_STDOUT in <root> below. -->
    <appender name="JSON_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>requestId</includeMdcKeyName>
            <timeZone>UTC</timeZone>
        </encoder>
    </appender>

    <logger name="com.example.translator" level="INFO"/>
    <logger name="org.eclipse.jetty" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
