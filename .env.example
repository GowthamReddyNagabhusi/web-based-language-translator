# Environment variables for local development
# Copy this file to .env and fill in real values — .env is gitignored

# ─── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── Database (local Docker) ───────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=translator_user
DB_PASSWORD=password

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── AWS (LocalStack for local dev, real values injected in prod via CI/CD) ────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT=http://localhost:4566

# ─── S3 ────────────────────────────────────────────────────────────────────────
S3_EXPORT_BUCKET=translator-exports-local

# ─── SQS ───────────────────────────────────────────────────────────────────────
SQS_BULK_QUEUE_NAME=bulk-translations-queue-local

# ─── JWT ───────────────────────────────────────────────────────────────────────
# For prod: RSA private key stored in AWS Secrets Manager.
# For local: key generated in-memory at startup.
JWT_SECRET_KEY_ID=local-dev-jwt-key
